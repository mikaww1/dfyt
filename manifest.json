{
  "manifest_version": 3,
  "name": "Distraction Free YT",
  "version": "0.3.0",
  "description": "Hide Shorts, recommendations, comments, and other distracting elements on YouTube.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Distraction Free YT"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": [
        "src/storage.js",
        "src/rules.js",
        "src/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
